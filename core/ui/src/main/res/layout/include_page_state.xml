<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:visibility="gone">

    <ProgressBar
        android:id="@+id/progress_page_state"
        style="?android:attr/progressBarStyle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:indeterminate="true" />

    <TextView
        android:id="@+id/tv_page_state_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title"
        android:textColor="@color/ui_light_on_surface"
        android:text="@string/page_state_loading_title" />

    <TextView
        android:id="@+id/tv_page_state_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body"
        android:text="@string/page_state_loading_desc" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_page_state_retry"
        style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/page_state_retry"
        android:visibility="gone" />
</LinearLayout>
