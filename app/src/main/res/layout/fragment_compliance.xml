<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_geometry">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/ui_grid_2"
        android:paddingTop="@dimen/ui_grid_3"
        android:paddingEnd="@dimen/ui_grid_2"
        android:paddingBottom="@dimen/ui_grid_2">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_header"
            style="@style/Widget.LowAltitudeRestStop.CardView.Hero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AIRSPACE CONTROL"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Eyebrow" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="企业飞行管理"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                <TextView
                    android:id="@+id/tv_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="统一处理飞行申请审核与禁飞区维护。"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_auth_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="审批与禁飞区能力已准备就绪"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
                    android:textColor="@color/ui_light_on_surface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ui_card_spacing"
            style="@style/Widget.LowAltitudeRestStop.CardView.Panel">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="飞行申请"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                <TextView
                    android:id="@+id/tv_application_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="查看待处理、已批准、已拒绝记录，并支持审批意见和批量操作。"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="进入飞行申请管理"
                    app:cornerRadius="@dimen/ui_radius_medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ui_card_spacing"
            style="@style/Widget.LowAltitudeRestStop.CardView.Panel">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="禁飞区"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                <TextView
                    android:id="@+id/tv_zone_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="维护禁飞区列表，支持坐标范围、生效时段和原因说明配置。"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_zones"
                    style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="进入禁飞区管理"
                    app:cornerRadius="@dimen/ui_radius_medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
