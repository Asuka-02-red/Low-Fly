<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="企业注册材料"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
            android:textColor="@color/ui_light_on_primary_container" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="企业资料上传"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Header"
            android:textColor="@color/ui_light_on_primary_container" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="请填写企业基础信息，并上传营业执照后保存返回。"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body"
            android:textColor="@color/ui_info_title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_auth_sheet"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="必填项"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_enterprise_name"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="企业名称 *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_enterprise_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_credit_code"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="统一社会信用代码 *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_credit_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_contact_name"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="联系人姓名 *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_contact_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_contact_phone"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="联系人手机号 *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_contact_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="营业执照 *"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
                android:textColor="@color/ui_light_on_surface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_license"
                style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="上传营业执照"
                app:icon="@drawable/ic_quick_profile"
                app:iconGravity="textStart" />

            <TextView
                android:id="@+id/tv_license_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="未选择文件"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_materials"
                style="@style/Widget.LowAltitudeRestStop.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="保存并返回" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
