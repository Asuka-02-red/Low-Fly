<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_light_background">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/layout_map_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ui_surface_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_map_placeholder_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="基础路线视图"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <TextView
            android:id="@+id/tv_map_placeholder_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="当前设备已切换到安全模式，页面将展示模拟路线、作业范围和禁飞区摘要。"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/ui_grid_2"
        android:layout_marginTop="@dimen/ui_grid_3"
        android:layout_marginEnd="@dimen/ui_grid_2"
        android:background="@color/ui_surface_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.LowAltitudeRestStop.Button.Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="返回"
            android:icon="@drawable/ic_action_back"
            android:text="" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="任务地图"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <TextView
                android:id="@+id/tv_route_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="正在加载执行路线与禁飞区"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
                android:textColor="@color/ui_text_muted" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
