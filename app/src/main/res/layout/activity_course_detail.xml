<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_geometry"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/training_screen_padding">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_course_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="-"
                android:textColor="@color/ui_light_on_primary_container"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_glass_panel"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="-"
                android:textColor="@color/ui_light_on_surface"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/course_detail_intro_title"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_institution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="-"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_course_stat"
                android:orientation="vertical"
                android:padding="11dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/course_detail_price_title"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                <TextView
                    android:id="@+id/tv_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="-"
                    android:textColor="@color/ui_text_primary"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_course_stat"
                android:orientation="vertical"
                android:padding="11dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/course_detail_seat_title"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                <TextView
                    android:id="@+id/tv_seat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="-"
                    android:textColor="@color/ui_text_primary"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="-"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/course_detail_content_title"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_glass_panel"
            android:lineSpacingExtra="6dp"
            android:padding="11dp"
            android:textColor="@color/ui_text_secondary"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            style="@style/Widget.LowAltitudeRestStop.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/course_detail_action_view" />
    </LinearLayout>
</ScrollView>
