<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_course_editor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_light_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/training_screen_padding">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/course_editor_title"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="11dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/course_editor_basic_title"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_course_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/course_editor_title_hint"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_course_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:hint="@string/course_editor_summary_hint"
                    android:minLines="3"
                    android:inputType="textMultiLine"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="11dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/course_editor_settings_title"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/course_editor_mode_label"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

            <Spinner
                android:id="@+id/sp_learning_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_seat_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/course_editor_seat_hint"
                    android:inputType="number"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/course_editor_price_hint"
                    android:inputType="numberDecimal"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="11dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/course_editor_content_title"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="180dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_course_content"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="top|start"
                    android:hint="@string/course_editor_content_hint"
                    android:inputType="textMultiLine"
                    android:minLines="7"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_draft"
                style="@style/Widget.LowAltitudeRestStop.Button.Ghost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/course_editor_save_draft" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_publish_course"
                style="@style/Widget.LowAltitudeRestStop.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/course_editor_publish" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
