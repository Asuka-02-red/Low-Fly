<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_message_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <TextView
        android:id="@+id/tv_detail_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_message_avatar"
        android:gravity="center"
        android:text="飞"
        android:textColor="@android:color/white"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layout_bubble_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_detail_sender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="发送者"
            android:textColor="@color/ui_light_on_surface_variant"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

        <TextView
            android:id="@+id/tv_detail_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autoSizeMaxTextSize="13.5sp"
            android:autoSizeMinTextSize="7.2sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:background="@drawable/bg_chat_bubble_other"
            android:breakStrategy="balanced"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="6"
            android:maxWidth="260dp"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="消息内容"
            android:textColor="@color/ui_light_on_surface"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.MessageBody" />

        <LinearLayout
            android:id="@+id/layout_detail_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_detail_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="刚刚"
                android:textColor="@color/ui_light_on_surface_variant"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

            <ImageView
                android:id="@+id/iv_detail_status"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="6dp"
                android:contentDescription="未读图标"
                android:src="@drawable/ic_message_status_check" />

            <TextView
                android:id="@+id/tv_detail_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="未读"
                android:textColor="@color/ui_light_on_surface_variant"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
