<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_geometry"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/ui_grid_2"
        android:paddingTop="@dimen/ui_grid_3"
        android:paddingEnd="@dimen/ui_grid_2"
        android:paddingBottom="@dimen/ui_grid_4">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.LowAltitudeRestStop.CardView.Hero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_weather_icon"
                        android:layout_width="@dimen/ui_weather_icon_detail_size"
                        android:layout_height="@dimen/ui_weather_icon_detail_size"
                        android:contentDescription="@string/home_weather_condition_label"
                        android:src="@drawable/ic_weather_cloudy" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ui_grid_2"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_weather_location_placeholder"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_weather"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/home_weather_loading_short"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Eyebrow" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_result"
                                style="@style/Widget.LowAltitudeRestStop.Badge.Success"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_grid_2"
                    android:text="@string/home_weather_loading_detail"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.LowAltitudeRestStop.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ui_grid_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/ui_metric_icon_size"
                        android:layout_height="@dimen/ui_metric_icon_size"
                        android:background="@drawable/bg_detail_metric_icon_thunder"
                        android:padding="6dp"
                        android:src="@drawable/ic_detail_thunder"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="@string/home_weather_risk_section"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                    <TextView
                        android:id="@+id/tv_risk_level"
                        style="@style/Widget.LowAltitudeRestStop.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="L1" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_thunderstorm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_grid_2"
                    android:text="@string/placeholder_dash"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Header" />

                <View
                    android:id="@+id/view_risk_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/ui_weather_risk_bar_height"
                    android:layout_marginTop="@dimen/ui_grid_2"
                    android:background="@drawable/bg_weather_risk_gradient" />

                <TextView
                    android:id="@+id/tv_risk_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_grid_1"
                    android:text="@string/home_weather_risk_hint_placeholder"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.LowAltitudeRestStop.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ui_grid_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ui_card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_weather_metric_section"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_grid_2"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_temp"
                            android:padding="6dp"
                            android:src="@drawable/ic_detail_temp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_temperature_label"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_temperature"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_humidity"
                            android:padding="6dp"
                            android:src="@drawable/ic_detail_humidity"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_humidity_label"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_humidity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_card_spacing"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_wind"
                            android:padding="6dp"
                            android:src="@drawable/ic_detail_wind"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_wind_label"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_wind"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_visibility"
                            android:padding="6dp"
                            android:src="@drawable/ic_detail_visibility"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_visibility_label"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_visibility"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_card_spacing"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_precipitation"
                            android:padding="6dp"
                            android:src="@drawable/ic_detail_precipitation"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_precipitation_short"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_precipitation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_chip"
                        android:gravity="center"
                        android:minHeight="64dp"
                        android:orientation="vertical"
                        android:padding="@dimen/ui_card_padding_compact">

                        <ImageView
                            android:layout_width="@dimen/ui_metric_icon_size"
                            android:layout_height="@dimen/ui_metric_icon_size"
                            android:background="@drawable/bg_detail_metric_icon_thunder"
                            android:padding="6dp"
                            android:src="@drawable/ic_weather_thunderstorm"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="@string/home_weather_thunderstorm_label"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />

                        <TextView
                            android:id="@+id/tv_thunderstorm_metric"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/placeholder_dash"
                            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.WeatherValue" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
