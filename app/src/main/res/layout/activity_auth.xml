<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gradient"
    android:clipToPadding="false"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/view_orb_primary"
            android:layout_width="188dp"
            android:layout_height="188dp"
            android:alpha="0.92"
            android:background="@drawable/bg_auth_orb_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/view_orb_secondary"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:alpha="0.74"
            android:background="@drawable/bg_auth_orb_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/view_orb_primary" />

        <LinearLayout
            android:id="@+id/layout_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW ALTITUDE HUB"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Eyebrow.Preserve" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="低空站点一体化入口"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Title.Preserve"
                android:textColor="@color/ui_light_on_primary_container" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="面向飞手、企业与监管协同的任务调度、飞行合规、经营联动与 AI 助理统一门户。"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Subtitle.Preserve"
                android:textColor="@color/ui_light_on_surface_variant" />



            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_auth_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="统一调度"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Chip.Preserve"
                        android:textColor="@color/ui_light_on_primary_container" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_auth_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="安全合规"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Chip.Preserve"
                        android:textColor="@color/ui_light_on_primary_container" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_auth_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="经营协同"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Chip.Preserve"
                        android:textColor="@color/ui_light_on_primary_container" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_auth_metric"
                    android:orientation="vertical"
                    android:padding="11dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="业务接入"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.MetricLabel.Preserve"
                        android:textColor="@color/ui_light_on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="统一身份"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.MetricValue.Preserve"
                        android:textColor="@color/ui_light_on_primary_container" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_auth_metric"
                    android:orientation="vertical"
                    android:padding="11dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="管控能力"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.MetricLabel.Preserve"
                        android:textColor="@color/ui_light_on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="权限隔离"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.MetricValue.Preserve"
                        android:textColor="@color/ui_light_on_primary_container" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_access"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_auth_sheet"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_hero">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/view_login_lottie"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@null"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/ai_login_orbit" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="低空登录"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Title.Preserve" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="支持正式账号登录与现场开户注册，适配企业侧日常运营与项目协同场景。"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Body.Preserve" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="账号信息"
                android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Auth.Caption.Preserve"
                android:textColor="@color/ui_light_on_surface" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_username"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="用户名">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="用户名输入框"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="密码">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="密码输入框"
                    android:inputType="textPassword"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_remember_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="记住密码"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body.Preserve" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_auto_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:checked="false"
                        android:text="自动登录"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body.Preserve" />
                </FrameLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_phone"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="手机号"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="手机号输入框"
                    android:inputType="phone"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_role"
                style="@style/Widget.LowAltitudeRestStop.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="账号类型"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/sp_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:spinnerMode="dropdown" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_upload_materials"
                style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="上传材料"
                android:visibility="gone"
                app:icon="@drawable/ic_quick_profile"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                style="@style/Widget.LowAltitudeRestStop.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:contentDescription="提交登录或注册"
                android:text="登录并进入" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle_mode"
                style="@style/Widget.LowAltitudeRestStop.Button.Ghost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="没有账号？去注册" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
