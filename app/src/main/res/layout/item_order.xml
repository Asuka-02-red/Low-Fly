<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/Widget.LowAltitudeRestStop.CardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="订单流程"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Eyebrow" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_metric_chip"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
