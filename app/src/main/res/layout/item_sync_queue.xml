<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="9dp"
    style="@style/Widget.LowAltitudeRestStop.CardView.Panel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="11dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title"
            android:textColor="@color/ui_text_primary" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body"
            android:textColor="@color/ui_text_secondary" />

        <TextView
            android:id="@+id/tv_request_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
            android:textColor="@color/ui_text_muted" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
            android:textColor="@color/ui_text_muted" />

        <TextView
            android:id="@+id/tv_payload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
            android:textColor="@color/ui_text_primary" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/placeholder_dash"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
            android:textColor="@color/ui_error" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/sync_retry_item" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

