<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_geometry"
    android:paddingStart="@dimen/ui_grid_2"
    android:paddingTop="@dimen/ui_grid_3"
    android:paddingEnd="@dimen/ui_grid_2"
    android:paddingBottom="@dimen/ui_grid_2">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/no_fly_zone_title"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_add_zone" />

    <TextView
        android:id="@+id/tv_network_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="在线同步中"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
        android:textColor="@color/ui_text_muted"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_add_zone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_zone"
        style="@style/Widget.LowAltitudeRestStop.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="添加"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_search"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tv_network_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="搜索禁飞区名称、原因或说明"
            android:imeOptions="actionSearch"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_map"
        style="@style/Widget.LowAltitudeRestStop.CardView.Panel"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/layout_search"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/map_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/layout_map_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_map_placeholder_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="禁飞区地图摘要"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

                <TextView
                    android:id="@+id/tv_map_placeholder_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="当前设备已切换到安全模式，页面将展示禁飞区数量、状态和摘要信息。"
                    android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:background="@drawable/bg_glass_panel"
                android:orientation="horizontal"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_fly_zone_map_title"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title"
                        android:textColor="@color/ui_text_primary" />

                    <TextView
                        android:id="@+id/tv_map_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/no_fly_zone_map_hint"
                        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Caption"
                        android:textColor="@color/ui_text_muted" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_fullscreen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="@drawable/ic_action_back"
                    android:rotation="135"
                    android:contentDescription="全屏显示" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/ui_card_spacing"
        app:layout_constraintTop_toBottomOf="@id/card_map"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="12dp" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="暂无禁飞区"
        android:textColor="@color/ui_text_hint"
        android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/swipe"
        app:layout_constraintBottom_toBottomOf="@id/swipe"
        app:layout_constraintStart_toStartOf="@id/swipe"
        app:layout_constraintEnd_toEndOf="@id/swipe" />

</androidx.constraintlayout.widget.ConstraintLayout>
