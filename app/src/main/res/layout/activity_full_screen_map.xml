<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_light_background">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/layout_map_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ui_surface_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_map_placeholder_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="禁飞区全屏摘要"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Title" />

        <TextView
            android:id="@+id/tv_map_placeholder_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="当前设备已切换到安全模式，页面将展示禁飞区摘要，不再加载高德地图实例。"
            android:textAppearance="@style/TextAppearance.LowAltitudeRestStop.Body" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
