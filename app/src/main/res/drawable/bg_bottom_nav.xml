<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="33dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_nav_glow" />
        </shape>
    </item>

    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ui_nav_shadow" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ui_nav_background_solid" />
            <corners android:radius="31dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/ui_nav_gradient_start"
                android:centerColor="@color/ui_nav_gradient_center"
                android:endColor="@color/ui_nav_gradient_end" />
            <corners android:radius="31dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ui_nav_overlay" />
            <corners android:radius="31dp" />
        </shape>
    </item>

    <item
        android:left="6dp"
        android:top="2dp"
        android:right="6dp"
        android:bottom="38dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ui_nav_highlight"
                android:endColor="@android:color/transparent" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/ui_nav_inner_shadow"
                android:endColor="@android:color/transparent" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_glass_border" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_glass_border" />
        </shape>
    </item>
</layer-list>
