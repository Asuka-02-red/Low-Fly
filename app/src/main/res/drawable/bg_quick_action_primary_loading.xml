<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/ui_quick_action_primary_pressed_start"
                android:endColor="@color/ui_quick_action_primary_pressed_end" />
            <corners android:radius="@dimen/ui_quick_action_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/ui_quick_action_loading_stroke" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ui_quick_action_loading_overlay" />
            <corners android:radius="@dimen/ui_quick_action_corner_radius" />
        </shape>
    </item>
</layer-list>
