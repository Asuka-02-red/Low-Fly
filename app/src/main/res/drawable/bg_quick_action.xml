<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="0"
                        android:startColor="@color/ui_quick_action_disabled_start"
                        android:endColor="@color/ui_quick_action_disabled_end" />
                    <corners android:radius="@dimen/ui_quick_action_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/ui_glass_border" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/ui_quick_action_secondary_pressed_start" />
                    <corners android:radius="@dimen/ui_quick_action_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/ui_glass_border" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/ui_quick_action_secondary_start" />
                    <corners android:radius="@dimen/ui_quick_action_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/ui_glass_border" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
