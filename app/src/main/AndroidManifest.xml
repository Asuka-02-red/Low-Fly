<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"
        tools:targetApi="34" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />

    <application
        android:name=".LowAltitudeApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="${usesCleartextTraffic}"
        android:theme="@style/Theme.LowaltitudeRestStop">
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="4d1e8d4add23fa46d8f786a309dc4a76" />

        <activity
            android:name=".feature.auth.AuthActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.EnterpriseMaterialsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.task.CreateTaskActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.task.TaskDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.task.TaskMapFullScreenActivity"
            android:exported="false" />

        <activity
            android:name=".feature.order.OrderListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.order.OrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".feature.order.PaymentActivity"
            android:exported="false" />

        <activity
            android:name=".feature.home.WeatherDetailActivity"
            android:exported="false" />

        <activity
            android:name=".feature.compliance.NoFlyZoneListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.compliance.FullScreenMapActivity"
            android:exported="false" />

        <activity
            android:name=".feature.compliance.AddNoFlyZoneActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.compliance.FlightApplicationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.compliance.FlightApplicationManageActivity"
            android:exported="false" />

        <activity
            android:name=".feature.risk.AlertListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.risk.AlertDetailActivity"
            android:exported="false" />

        <activity
            android:name=".feature.training.CourseListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.training.CourseDetailActivity"
            android:exported="false" />

        <activity
            android:name=".feature.training.CourseEditorActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.profile.OperationLogActivity"
            android:exported="false" />

        <activity
            android:name=".feature.profile.SyncQueueActivity"
            android:exported="false" />

        <activity
            android:name=".feature.profile.MessageCenterActivity"
            android:exported="false" />

        <activity
            android:name=".feature.profile.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".feature.profile.HelpFeedbackActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.permission.PermissionRequestActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:finishOnTaskLaunch="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.LowaltitudeRestStop.PermissionProxy" />

        <activity
            android:name=".feature.message.MessageListActivity"
            android:exported="false" />

        <activity
            android:name=".feature.message.MessageDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".feature.message.MessageThreadActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".feature.ai.service.AiBallBinderService"
            android:enabled="@bool/enable_ai_ball"
            android:exported="false" />

        <service
            android:name=".feature.ai.service.AiBallAccessibilityService"
            android:enabled="@bool/enable_ai_ball"
            android:exported="false"
            android:label="@string/ai_ball_accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/ai_ball_accessibility_service" />
        </service>
    </application>

</manifest>
